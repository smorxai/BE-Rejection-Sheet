# Neon PostgreSQL - Pooled connection (used by app at runtime via PgBouncer)
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"

# Neon PostgreSQL - Direct connection (used by Prisma for migrations)
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# NextAuth - generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Anthropic API Key (optional - AI features degrade gracefully without it)
ANTHROPIC_API_KEY="sk-ant-api03-..."
